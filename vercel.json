{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "game.js", "use": "@vercel/static" },
    { "src": "llm.js", "use": "@vercel/static" },
    { "src": "sound.js", "use": "@vercel/static" },
    { "src": "styles.css", "use": "@vercel/static" },
    { "src": "images/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/chat", "dest": "/api/chat" },
    { "src": "/health", "dest": "/api/health" },
    { "src": "/status", "dest": "/api/status" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
